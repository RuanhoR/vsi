fun FileTest() {
  var filePath = process.path.join(process.cwd, "example", "HelloWorld.vsi")
  process.stdout.write("File path: " + filePath + "\n")
  var fileContent = process.file.readFile(filePath)
  process.stdout.write("File content (without String.new):\n")
  process.stdout.write(fileContent + "\n")
}
FileTest()